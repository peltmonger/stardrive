---
import Layout from "@layouts/default.astro";
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { themeConfig } from '~/theme.config';
import { useTranslations } from "@utils/i18n";

const locale = themeConfig.i18n.defaultLocale;
const t = useTranslations(locale);

export async function getStaticPaths() {
  const locale = themeConfig.i18n.defaultLocale;
  const entries = (await getCollection('integration_options', ({ id, data }) => {
    return !data.draft && id.startsWith(locale + '/');
  })) as CollectionEntry<'integration_options'>[];

  const types = Array.from(new Set(entries.map((e) => e.data.type)));

  return types.map((type) => {
    const firstItem = entries
      .filter((e) => e.data.type === type)
      .sort((a, b) => a.data.service.localeCompare(b.data.service))[0];
    const slug = firstItem.id.split('/')[1];
    return {
      params: { type },
      props: { item: slug },
    };
  });
}

return Astro.redirect(`/integration/${Astro.params.type}/${Astro.props.item}`, 302);
---

<Layout title={t('pages.integration.title')} description={t('pages.integration.description')}></Layout>